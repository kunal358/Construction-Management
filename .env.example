# Flask production settings
SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=false

# Set these to enable the login screen.
AB_AUTH_USERNAME=admin

# Recommended: use a password hash instead of plain text.
# Generate one on the server with:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
AB_AUTH_PASSWORD_HASH=replace-with-generated-password-hash

# Temporary/simple option if you do not want to generate a hash yet.
# Leave AB_AUTH_PASSWORD_HASH empty if using this.
# AB_AUTH_PASSWORD=change-this-password
